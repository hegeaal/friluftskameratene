# Friluftskompis – miljøvariabler
#
# Kopier til .env og fyll inn faktiske verdier. .env er gitignorert.
# Hemmeligheter ligger i Blank 1Password under "Italia - Hackathon-nøkler".

# ---------------------------------------------------------------------------
# Identifikatorer for åpne APIer (ikke hemmelig, men kreves i headere)
# ---------------------------------------------------------------------------

# MET Norway / Yr – User-Agent må inkludere appnavn og kontakt
MET_USER_AGENT="Friluftskompis/1.0 team@blank.no"

# Entur – klientidentifikator for å unngå throttling
ENTUR_CLIENT_NAME="blank-friluftskompis"

# ---------------------------------------------------------------------------
# DATEX II v3 (Vegvesen sanntid) – HTTP Basic Auth
# 1Password: Italia - Hackathon-nøkler → DATEX
# ---------------------------------------------------------------------------
DATEX_USERNAME="TjeDatexBlank"
DATEX_PASSWORD=""

# ---------------------------------------------------------------------------
# Apify (Airbnb-scraper)
# 1Password: Italia - Hackathon-nøkler → APIFY
# ---------------------------------------------------------------------------
APIFY_API_TOKEN=""

# ---------------------------------------------------------------------------
# Strava (OAuth 2.0)
# 1Password: Italia - Hackathon-nøkler → STRAVA
# Access token utløper etter 6t – bruk refresh token
# ---------------------------------------------------------------------------
STRAVA_CLIENT_ID=""
STRAVA_CLIENT_SECRET=""
STRAVA_ACCESS_TOKEN=""
STRAVA_REFRESH_TOKEN=""

# ---------------------------------------------------------------------------
# Google Maps Platform
# 1Password: Italia - Hackathon-nøkler → Google Maps API Key - hackathon
# ---------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=""

# ---------------------------------------------------------------------------
# Anthropic / Claude API
# Hvert teammedlem bruker egen Anthropic-konto – ikke i delt 1Password
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=""
